{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        ".github/workflows/*.{yml,yaml}"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+.*@(?<currentValue>[^\\s@]+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}npm{{/if}}"
    }
  ]
}
